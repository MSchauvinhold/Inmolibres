generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Rol {
  SUPERADMIN
  ADMIN
  AGENTE
  PARTICULAR

  @@map("rol")
}

enum EstadoInmobiliaria {
  ACTIVA
  INACTIVA
  PRUEBA
  SUSPENDIDA

  @@map("estado_inmobiliaria")
}

enum TipoPropiedad {
  CASA
  DEPARTAMENTO
  LOCAL
  GALPON
  TERRENO
  OFICINA

  @@map("tipo_propiedad")
}

enum TipoOperacion {
  VENTA
  ALQUILER
  ALQUILER_TEMPORARIO

  @@map("tipo_operacion")
}

enum EstadoPropiedad {
  DISPONIBLE
  RESERVADA
  ALQUILADA
  VENDIDA

  @@map("estado_propiedad")
}

enum EstadoPipeline {
  NUEVO
  CONTACTADO
  VISITA_AGENDADA
  SEGUNDA_VISITA
  CERRADO
  PERDIDO

  @@map("estado_pipeline")
}

enum OrigenLead {
  INSTAGRAM
  WHATSAPP
  CONSULTA_LOCAL
  REFERIDO
  PORTAL
  OTRO

  @@map("origen_lead")
}

enum TipoVisita {
  VISITA_COMPRADOR
  VISITA_VENDEDOR

  @@map("tipo_visita")
}

enum EstadoVisita {
  PENDIENTE
  REALIZADA
  CANCELADA

  @@map("estado_visita")
}

enum EstadoPago {
  AL_DIA
  ATRASADO

  @@map("estado_pago")
}

enum Moneda {
  ARS
  USD

  @@map("moneda")
}

enum TipoNotificacion {
  SUSCRIPCION_7_DIAS
  SUSCRIPCION_5_DIAS
  SUSCRIPCION_2_DIAS
  SUSCRIPCION_24_HORAS
  SUSCRIPCION_VENCIDA
  SUSCRIPCION_SUSPENDIDA
  SUSCRIPCION_RENOVADA
  VISITA_PROXIMA
  CONTRATO_POR_VENCER
  PAGO_ATRASADO
  LEAD_FRIO
  CONSULTA_NUEVA

  @@map("tipo_notificacion")
}

enum TipoDocumento {
  DNI_FRENTE
  DNI_DORSO
  RECIBO_SUELDO
  RECIBO_SUELDO_GARANTE
  DNI_GARANTE_FRENTE
  DNI_GARANTE_DORSO
  ESCRITURA_PROPIEDAD
  PLANO_APROBADO
  CONSTANCIA_CUIL
  CONSTANCIA_CUIL_GARANTE
  CONTRATO_FIRMADO
  BOLETO_COMPRAVENTA
  RECIBO_PAGO
  FOTO_ESTADO_INMUEBLE
  OTRO

  @@map("tipo_documento")
}

enum RolContacto {
  PROPIETARIO
  INQUILINO
  COMPRADOR

  @@map("rol_contacto")
}

enum TipoOperacionFinanciera {
  VENTA
  ALQUILER
  ALQUILER_TEMPORARIO

  @@map("tipo_operacion_financiera")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Inmobiliaria {
  id               String             @id @default(dbgenerated("gen_random_uuid()"))
  nombre           String
  logoUrl          String?            @map("logo_url")
  whatsapp         String
  email            String
  plan             String             @default("AVANZADO")
  estado           EstadoInmobiliaria @default(PRUEBA)
  fechaVencimiento DateTime?          @map("fecha_vencimiento") @db.Timestamptz(6)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)

  usuarios         Usuario[]
  propiedades      Propiedad[]
  clientes         Cliente[]
  visitas          Visita[]
  contratos        ContratoAlquiler[]
  contratosVenta   ContratoVenta[]
  consultas        Consulta[]
  pagos            PagoSuscripcion[]
  pagosRegistro    PagoRegistro[]
  configuracion    ConfiguracionInmobiliaria?
  operaciones      OperacionCerrada[]
  egresos          EgresoInmobiliaria[]
  documentosCliente DocumentoCliente[]
  contactos         Contacto[]

  @@map("inmobiliarias")
}

model Usuario {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  inmobiliariaId String?  @map("inmobiliaria_id")
  email          String   @unique
  passwordHash   String   @map("password_hash")
  nombre         String
  rol            Rol
  activo              Boolean  @default(true)
  comisionPersonalPct Float?   @map("comision_personal_pct")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  inmobiliaria        Inmobiliaria?        @relation(fields: [inmobiliariaId], references: [id], onUpdate: NoAction)
  propiedades         Propiedad[]
  visitas             Visita[]
  clientesAsignados   Cliente[]
  notificaciones      Notificacion[]
  permisos            PermisosAgente?
  operaciones         OperacionCerrada[]
  passwordResetTokens PasswordResetToken[]

  @@index([inmobiliariaId], map: "idx_usuarios_inmobiliaria")
  @@map("usuarios")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  usuarioId String   @map("usuario_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId], map: "idx_prt_usuario")
  @@map("password_reset_tokens")
}

model Propiedad {
  id             String          @id @default(dbgenerated("gen_random_uuid()"))
  inmobiliariaId String?         @map("inmobiliaria_id")
  titulo         String
  slug           String          @unique
  tipo           TipoPropiedad
  operacion      TipoOperacion
  precio         Decimal         @db.Decimal(15, 2)
  moneda         Moneda          @default(USD)
  direccion      String
  latitud        Float?
  longitud       Float?
  poligonoJson   Json?           @map("poligono_json")
  estado         EstadoPropiedad @default(DISPONIBLE)
  descripcion    String?
  videoUrl       String?         @map("video_url")
  publicada      Boolean         @default(true)
  // agenteId nullable: null = publicada a nombre de la inmobiliaria (sin asesor específico)
  agenteId       String?         @map("agente_id")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)

  inmobiliaria        Inmobiliaria?      @relation(fields: [inmobiliariaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  agente              Usuario?           @relation(fields: [agenteId], references: [id], onUpdate: NoAction)
  atributos           PropiedadAtributos?
  fotos               FotoPropiedad[]
  clientesInteresados PropiedadCliente[]
  visitas             Visita[]
  contratos           ContratoAlquiler[]
  consultas           Consulta[]

  @@index([inmobiliariaId], map: "idx_propiedades_inmobiliaria")
  @@index([tipo, operacion], map: "idx_propiedades_tipo_operacion")
  @@index([publicada, estado], map: "idx_propiedades_publicada")
  @@map("propiedades")
}

model PropiedadAtributos {
  id                    String   @id @default(dbgenerated("gen_random_uuid()"))
  propiedadId           String   @unique @map("propiedad_id")
  superficieCubierta    Float?   @map("superficie_cubierta")
  superficieTotal       Float?   @map("superficie_total")
  habitaciones          Int?
  banos                 Int?
  garage                Boolean?
  pileta                Boolean?
  quincho               Boolean?
  balcon                Boolean?
  amueblado             Boolean?
  cantidadPisos         Int?     @map("cantidad_pisos")
  numeroPiso            Int?     @map("numero_piso")
  mostrarPrecioPorM2    Boolean  @default(false) @map("mostrar_precio_por_m2")
  precioPorDia          Decimal? @map("precio_por_dia") @db.Decimal(15, 2)
  precioSemana          Decimal? @map("precio_semana") @db.Decimal(15, 2)
  precioQuincena        Decimal? @map("precio_quincena") @db.Decimal(15, 2)
  diasMinimos           Int?     @map("dias_minimos")
  diasMaximos           Int?     @map("dias_maximos")
  anchoMetros           Float?   @map("ancho_metros")
  largoMetros           Float?   @map("largo_metros")
  alturaInterna         Float?   @map("altura_interna")
  serviciosAgua         Boolean? @map("servicios_agua")
  serviciosLuz          Boolean? @map("servicios_luz")
  serviciosGas          Boolean? @map("servicios_gas")
  serviciosCloaca       Boolean? @map("servicios_cloaca")
  caracteristicasCustom String[] @default([]) @map("caracteristicas_custom")

  propiedad Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("propiedades_atributos")
}

model FotoPropiedad {
  id            String  @id @default(dbgenerated("gen_random_uuid()"))
  propiedadId   String  @map("propiedad_id")
  urlCloudinary String  @map("url_cloudinary")
  orden         Int     @default(0)
  esPortada     Boolean @default(false) @map("es_portada")

  propiedad Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([propiedadId], map: "idx_fotos_propiedad")
  @@map("fotos_propiedades")
}

model Cliente {
  id             String         @id @default(dbgenerated("gen_random_uuid()"))
  inmobiliariaId String?        @map("inmobiliaria_id")
  nombre         String
  telefono       String
  email          String?
  origen         OrigenLead     @default(OTRO)
  estadoPipeline EstadoPipeline @default(NUEVO) @map("estado_pipeline")
  agenteId       String?        @map("agente_id")
  notas          String?
  ultimaActividad DateTime      @default(now()) @map("ultima_actividad") @db.Timestamptz(6)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  inmobiliaria Inmobiliaria?      @relation(fields: [inmobiliariaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  agente       Usuario?           @relation(fields: [agenteId], references: [id], onUpdate: NoAction)
  propiedades  PropiedadCliente[]
  visitas      Visita[]
  documentos   DocumentoCliente[]

  @@index([inmobiliariaId], map: "idx_clientes_inmobiliaria")
  @@index([estadoPipeline], map: "idx_clientes_pipeline")
  @@index([ultimaActividad], map: "idx_clientes_ultima_actividad")
  @@map("clientes")
}

model PropiedadCliente {
  propiedadId String @map("propiedad_id")
  clienteId   String @map("cliente_id")

  propiedad Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  cliente   Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([propiedadId, clienteId])
  @@map("propiedades_clientes")
}

model Visita {
  id             String       @id @default(dbgenerated("gen_random_uuid()"))
  propiedadId    String       @map("propiedad_id")
  clienteId      String       @map("cliente_id")
  agenteId       String       @map("agente_id")
  inmobiliariaId String?      @map("inmobiliaria_id")
  fechaHora      DateTime     @map("fecha_hora") @db.Timestamptz(6)
  tipo           TipoVisita
  estado         EstadoVisita @default(PENDIENTE)
  notasPost      String?      @map("notas_post")
  alertaEnviada  Boolean      @default(false) @map("alerta_enviada")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  propiedad    Propiedad     @relation(fields: [propiedadId], references: [id], onUpdate: NoAction)
  cliente      Cliente       @relation(fields: [clienteId], references: [id], onUpdate: NoAction)
  agente       Usuario       @relation(fields: [agenteId], references: [id], onUpdate: NoAction)
  inmobiliaria Inmobiliaria? @relation(fields: [inmobiliariaId], references: [id], onUpdate: NoAction)

  @@index([inmobiliariaId], map: "idx_visitas_inmobiliaria")
  @@index([fechaHora], map: "idx_visitas_fecha")
  @@index([alertaEnviada, estado, fechaHora], map: "idx_visitas_alerta")
  @@map("visitas")
}

model ContratoAlquiler {
  id                 String     @id @default(dbgenerated("gen_random_uuid()"))
  propiedadId        String     @map("propiedad_id")
  inmobiliariaId     String     @map("inmobiliaria_id")
  inquilinoNombre    String     @map("inquilino_nombre")
  inquilinoTel       String     @map("inquilino_tel")
  precioMensual      Decimal    @map("precio_mensual") @db.Decimal(15, 2)
  moneda             Moneda     @default(ARS)
  diaVencimientoPago Int        @map("dia_vencimiento_pago")
  estadoPago         EstadoPago @default(AL_DIA) @map("estado_pago")
  fechaInicio        DateTime   @map("fecha_inicio") @db.Date
  fechaFin           DateTime   @map("fecha_fin") @db.Date
  notas              String?
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  propiedad    Propiedad        @relation(fields: [propiedadId], references: [id], onUpdate: NoAction)
  inmobiliaria Inmobiliaria     @relation(fields: [inmobiliariaId], references: [id], onUpdate: NoAction)
  personas     ContratoPersona[]
  pagos        PagoRegistro[]

  @@index([inmobiliariaId], map: "idx_contratos_inmobiliaria")
  @@index([fechaFin], map: "idx_contratos_fecha_fin")
  @@map("contratos_alquiler")
}

model ContratoVenta {
  id                   String    @id @default(cuid())
  inmobiliariaId       String    @map("inmobiliaria_id")

  propiedadDireccion   String    @map("propiedad_direccion")
  propiedadDescripcion String?   @map("propiedad_descripcion")
  matriculaInmueble    String?   @map("matricula_inmueble")

  vendedorNombre       String    @map("vendedor_nombre")
  vendedorDni          String    @map("vendedor_dni")
  vendedorTel          String?   @map("vendedor_tel")
  vendedorDomicilio    String?   @map("vendedor_domicilio")
  vendedorEstadoCivil  String    @default("soltero") @map("vendedor_estado_civil")
  vendedorConyuge      String?   @map("vendedor_conyuge")

  compradorNombre      String    @map("comprador_nombre")
  compradorDni         String    @map("comprador_dni")
  compradorTel         String?   @map("comprador_tel")
  compradorDomicilio   String?   @map("comprador_domicilio")
  compradorEstadoCivil String    @default("soltero") @map("comprador_estado_civil")
  compradorConyuge     String?   @map("comprador_conyuge")

  precioVenta          Decimal   @map("precio_venta") @db.Decimal(15, 2)
  moneda               Moneda    @default(USD)
  sena                 Decimal?  @db.Decimal(15, 2)
  comisionVendedorPct  Float     @default(3) @map("comision_vendedor_pct")
  comisionCompradorPct Float     @default(3) @map("comision_comprador_pct")
  formaPago            String    @default("Contado") @map("forma_pago")

  escribanoNombre      String?   @map("escribano_nombre")
  escribanoRegistro    String?   @map("escribano_registro")
  fechaEscritura       DateTime? @map("fecha_escritura") @db.Date

  clausulas            String?
  notas                String?

  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt      @map("updated_at") @db.Timestamptz(6)

  inmobiliaria Inmobiliaria @relation(fields: [inmobiliariaId], references: [id], onDelete: Cascade)

  @@index([inmobiliariaId], map: "idx_contratos_venta_inmobiliaria")
  @@map("contratos_venta")
}

model PagoRegistro {
  id             String   @id @default(cuid())
  contratoId     String   @map("contrato_id")
  inmobiliariaId String   @map("inmobiliaria_id")
  concepto       String   @db.VarChar(120)
  monto          Decimal  @db.Decimal(15, 2)
  moneda         Moneda   @default(ARS)
  metodoPago     String?  @map("metodo_pago") @db.VarChar(60)
  fecha          DateTime @default(now()) @db.Date
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  contrato     ContratoAlquiler @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  inmobiliaria Inmobiliaria     @relation(fields: [inmobiliariaId], references: [id], onDelete: Cascade)

  @@index([contratoId],     map: "idx_pagos_registro_contrato")
  @@index([inmobiliariaId], map: "idx_pagos_registro_inmobiliaria")
  @@map("pagos_registro")
}

model Consulta {
  id              String   @id @default(dbgenerated("gen_random_uuid()"))
  propiedadId     String?  @map("propiedad_id")
  inmobiliariaId  String?  @map("inmobiliaria_id")
  nombreVisitante String   @map("nombre_visitante")
  telefono        String
  email           String?
  mensaje         String
  origen          String   @default("MARKETPLACE")
  leida           Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  propiedad    Propiedad?    @relation(fields: [propiedadId], references: [id], onUpdate: NoAction)
  inmobiliaria Inmobiliaria? @relation(fields: [inmobiliariaId], references: [id], onUpdate: NoAction)

  @@index([inmobiliariaId], map: "idx_consultas_inmobiliaria")
  @@index([leida], map: "idx_consultas_leida")
  @@index([origen], map: "idx_consultas_origen")
  @@map("consultas")
}

model Notificacion {
  id           String           @id @default(dbgenerated("gen_random_uuid()"))
  usuarioId    String           @map("usuario_id")
  tipo         TipoNotificacion
  titulo       String
  mensaje      String
  leida        Boolean          @default(false)
  url          String?
  referenciaId String?          @map("referencia_id")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, leida], map: "idx_notificaciones_usuario_leida")
  @@index([referenciaId], map: "idx_notificaciones_referencia")
  @@index([createdAt(sort: Desc)], map: "idx_notificaciones_created")
  @@map("notificaciones")
}

model PagoSuscripcion {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  inmobiliariaId String   @map("inmobiliaria_id")
  monto          Decimal  @db.Decimal(15, 2)
  moneda         Moneda   @default(ARS)
  fechaPago      DateTime @map("fecha_pago") @db.Date
  notas          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  inmobiliaria Inmobiliaria @relation(fields: [inmobiliariaId], references: [id], onUpdate: NoAction)

  @@index([inmobiliariaId], map: "idx_pagos_inmobiliaria")
  @@map("pagos_suscripcion")
}

model ConfiguracionInmobiliaria {
  id                   String   @id @default(cuid())
  inmobiliariaId       String   @unique @map("inmobiliaria_id")

  comisionVendedorPct  Float    @default(3.0)  @map("comision_vendedor_pct")
  comisionCompradorPct Float    @default(3.0)  @map("comision_comprador_pct")
  comisionAlquilerMeses Float   @default(1.0)  @map("comision_alquiler_meses")
  comisionAgentePct    Float    @default(30.0) @map("comision_agente_pct")
  comisionInmobPct     Float    @default(70.0) @map("comision_inmob_pct")
  ivaIncluido          Boolean  @default(true) @map("iva_incluido")
  monedaPreferida      Moneda   @default(USD)  @map("moneda_preferida")

  colorPrimario        String   @default("#1B4332") @map("color_primario")
  colorSecundario      String   @default("#2C2C2C") @map("color_secundario")

  logoEnContrato       Boolean  @default(false) @map("logo_en_contrato")

  clausulasAdicionales String?  @map("clausulas_adicionales")
  piePaginaContrato    String?  @map("pie_pagina_contrato")

  cuit                 String?
  razonSocial          String?  @map("razon_social")
  domicilioLegal       String?  @map("domicilio_legal")
  matriculaCorredora   String?  @map("matricula_corredora")

  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt      @map("updated_at") @db.Timestamptz(6)

  inmobiliaria Inmobiliaria @relation(fields: [inmobiliariaId], references: [id], onDelete: Cascade)

  @@map("configuracion_inmobiliaria")
}

model PermisosAgente {
  id                String  @id @default(cuid())
  usuarioId         String  @unique @map("usuario_id")

  verPropiedades    Boolean @default(true)  @map("ver_propiedades")
  editarPropiedades Boolean @default(true)  @map("editar_propiedades")
  verClientes       Boolean @default(true)  @map("ver_clientes")
  editarClientes    Boolean @default(true)  @map("editar_clientes")
  verVisitas        Boolean @default(true)  @map("ver_visitas")
  editarVisitas     Boolean @default(true)  @map("editar_visitas")
  verAlquileres     Boolean @default(true)  @map("ver_alquileres")
  editarAlquileres  Boolean @default(false) @map("editar_alquileres")
  verConsultas      Boolean @default(true)  @map("ver_consultas")
  verCalculadoras   Boolean @default(true)  @map("ver_calculadoras")
  verFinanzas       Boolean @default(false) @map("ver_finanzas")
  verDocumentos     Boolean @default(true)  @map("ver_documentos")
  verReportes       Boolean @default(false) @map("ver_reportes")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("permisos_agente")
}

model DocumentoCliente {
  id             String        @id @default(cuid())
  clienteId      String        @map("cliente_id")
  inmobiliariaId String        @map("inmobiliaria_id")
  tipo           TipoDocumento
  nombre         String
  urlCloudinary  String        @map("url_cloudinary")
  esImagen       Boolean       @default(false) @map("es_imagen")
  notas          String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  cliente      Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  inmobiliaria Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])

  @@index([clienteId])
  @@index([inmobiliariaId])
  @@map("documentos_cliente")
}

model OperacionCerrada {
  id                   String                  @id @default(cuid())
  inmobiliariaId       String                  @map("inmobiliaria_id")
  propiedadId          String?                 @map("propiedad_id")
  clienteId            String?                 @map("cliente_id")
  agenteId             String                  @map("agente_id")

  tipo                 TipoOperacionFinanciera
  precioOperacion      Decimal                 @map("precio_operacion") @db.Decimal(15, 2)
  moneda               Moneda                  @default(USD)

  comisionVendedorPct  Float                   @map("comision_vendedor_pct")
  comisionCompradorPct Float                   @map("comision_comprador_pct")
  comisionTotal        Decimal                 @map("comision_total") @db.Decimal(15, 2)
  comisionInmob        Decimal                 @map("comision_inmob") @db.Decimal(15, 2)
  comisionAgente       Decimal                 @map("comision_agente") @db.Decimal(15, 2)
  ivaComision          Decimal                 @default(0) @map("iva_comision") @db.Decimal(15, 2)

  gastos               Decimal                 @default(0) @db.Decimal(15, 2)
  descripcionGastos    String?                 @map("descripcion_gastos")

  fechaCierre          DateTime                @default(now()) @map("fecha_cierre") @db.Timestamptz(6)
  notas                String?

  inmobiliaria Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])
  agente       Usuario      @relation(fields: [agenteId], references: [id])

  @@index([inmobiliariaId])
  @@index([fechaCierre])
  @@index([agenteId])
  @@map("operaciones_cerradas")
}

model EgresoInmobiliaria {
  id             String   @id @default(cuid())
  inmobiliariaId String   @map("inmobiliaria_id")
  concepto       String
  monto          Decimal  @db.Decimal(15, 2)
  moneda         Moneda   @default(ARS)
  fecha          DateTime @default(now()) @db.Timestamptz(6)
  categoria      String?

  inmobiliaria Inmobiliaria @relation(fields: [inmobiliariaId], references: [id])

  @@index([inmobiliariaId])
  @@map("egresos_inmobiliaria")
}

// ─── Contactos ────────────────────────────────────────────────────────────────

model Contacto {
  id              String        @id @default(cuid())
  inmobiliariaId  String        @map("inmobiliaria_id")
  roles           RolContacto[]
  nombre          String
  dni             String?
  fechaNacimiento DateTime?     @map("fecha_nacimiento")
  domicilio       String?
  telefono        String?
  email           String?
  estadoCivil     String?       @map("estado_civil")
  ocupacion       String?
  notas           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt      @map("updated_at")

  inmobiliaria Inmobiliaria        @relation(fields: [inmobiliariaId], references: [id], onDelete: Cascade)
  documentos   DocumentoContacto[]
  garante      Garante?
  contratos    ContratoPersona[]

  @@index([inmobiliariaId], map: "idx_contactos_inmobiliaria")
  @@map("contactos")
}

model Garante {
  id                  String    @id @default(cuid())
  contactoId          String    @unique @map("contacto_id")
  nombre              String
  dni                 String?
  fechaNacimiento     DateTime? @map("fecha_nacimiento")
  domicilio           String?
  telefono            String?
  relacionConContacto String?   @map("relacion_con_contacto")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt      @map("updated_at")

  contacto   Contacto            @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  documentos DocumentoContacto[]

  @@map("garantes")
}

model DocumentoContacto {
  id         String        @id @default(cuid())
  contactoId String?       @map("contacto_id")
  garanteId  String?       @map("garante_id")
  tipo       TipoDocumento
  label      String?
  url        String
  esImagen   Boolean       @default(false) @map("es_imagen")
  createdAt  DateTime      @default(now()) @map("created_at")

  contacto Contacto? @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  garante  Garante?  @relation(fields: [garanteId], references: [id], onDelete: Cascade)

  // NOTA: CHECK constraint a nivel DB que garantiza que al menos uno de
  // contacto_id / garante_id esté presente (no documentos huérfanos):
  //   chk_doc_contacto_owner CHECK (contacto_id IS NOT NULL OR garante_id IS NOT NULL)
  // Prisma no soporta CHECK en el schema declarativo — aplicado vía SQL directo.
  // Si recreás la DB, re-ejecutá ese ALTER TABLE.
  @@index([contactoId])
  @@index([garanteId])
  @@map("documentos_contacto")
}

model ContratoPersona {
  id         String @id @default(cuid())
  contratoId String @map("contrato_id")
  contactoId String @map("contacto_id")
  rol        String

  contrato ContratoAlquiler @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  contacto Contacto         @relation(fields: [contactoId], references: [id], onDelete: Cascade)

  @@unique([contratoId, contactoId, rol])
  @@map("contratos_personas")
}
